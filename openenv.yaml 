name: code-review-assistant
version: 1.0.0
description: AI agent learns to review code - detect bugs, classify severity, suggest fixes

author: Your Team Name
license: MIT

environment:
  class: CodeReviewEnvironment
  module: backend.environment

tasks:
  - id: 1
    name: bug_detection
    difficulty: easy
    max_steps: 2
    description: Detect if code contains bugs or security vulnerabilities
    evaluation_metric: accuracy
    
  - id: 2
    name: bug_classification
    difficulty: medium
    max_steps: 5
    description: Find all bugs and classify them by type and severity
    evaluation_metric: f1_score
    
  - id: 3
    name: fix_suggestion
    difficulty: hard
    max_steps: 3
    description: Suggest correct fix for identified bug with explanation
    evaluation_metric: quality_score

action_space:
  types:
    - detect_bug
    - classify_severity
    - suggest_fix
    - explain
    - skip

observation_space:
  code_context:
    - code
    - filename
    - line_count
  task_info:
    - task_id
    - description
    - step_count
    - max_steps
  progress:
    - bugs_found_so_far
    - total_bugs

reward_range: [0.0, 1.0]

dependencies:
  python: ">=3.8"
  packages:
    - pydantic>=2.0
    - flask>=2.0